#!/usr/bin/env bash

set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

mapfile -t staged_files < <(git diff --cached --name-only --diff-filter=ACMR)

if [ "${#staged_files[@]}" -eq 0 ]; then
    exit 0
fi

backend_rust_files=()
mobile_format_files=()

for file in "${staged_files[@]}"; do
    case "$file" in
        backend/*.rs)
            backend_rust_files+=("${file#backend/}")
            ;;
        wetty-chat-mobile/src/*.js|wetty-chat-mobile/src/*.jsx|wetty-chat-mobile/src/*.ts|wetty-chat-mobile/src/*.tsx|wetty-chat-mobile/src/*.json|wetty-chat-mobile/src/*.scss|wetty-chat-mobile/src/*.css)
            mobile_format_files+=("${file#wetty-chat-mobile/}")
            ;;
    esac
done

if [ "${#backend_rust_files[@]}" -gt 0 ]; then
    echo "pre-commit: checking Rust formatting for staged backend files"
    if ! (cd backend && cargo fmt --check -- "${backend_rust_files[@]}"); then
        echo "pre-commit: Rust formatting check failed."
        echo "Run: (cd backend && cargo fmt -- ${backend_rust_files[*]})"
        exit 1
    fi
fi

if [ "${#mobile_format_files[@]}" -gt 0 ]; then
    echo "pre-commit: checking Prettier formatting for staged frontend files"
    if ! (cd wetty-chat-mobile && npx prettier --check "${mobile_format_files[@]}"); then
        echo "pre-commit: Prettier formatting check failed."
        echo "Run: (cd wetty-chat-mobile && npx prettier --write ${mobile_format_files[*]})"
        exit 1
    fi
fi
