#!/usr/bin/env bash

set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

mapfile -t staged_files < <(git diff --cached --name-only --diff-filter=ACMR)

if [ "${#staged_files[@]}" -eq 0 ]; then
    exit 0
fi

has_backend_changes=0
has_mobile_changes=0

for file in "${staged_files[@]}"; do
    case "$file" in
        backend/*)
            has_backend_changes=1
            ;;
        wetty-chat-mobile/*)
            has_mobile_changes=1
            ;;
    esac
done

if [ "$has_backend_changes" -eq 1 ]; then
    echo "pre-commit: running cargo fmt in backend/"
    (cd backend && cargo fmt)
fi

if [ "$has_mobile_changes" -eq 1 ]; then
    echo "pre-commit: running npm run format in wetty-chat-mobile/"
    (cd wetty-chat-mobile && npm run format)
fi

for file in "${staged_files[@]}"; do
    if [ -f "$file" ]; then
        git add -- "$file"
    fi
done
