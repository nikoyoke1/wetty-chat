# Copy to .env and set your database URL.
# DATABASE_URL is read by the app and by Diesel CLI (e.g. diesel migration run).
DATABASE_URL=postgres://user:password@localhost/wetty_chat

# AWS
S3_BUCKET_NAME=wetty-chat-local-dev
AWS_REGION=us-west-2

# VAPID keys
# Generate with `npx web-push generate-vapid-keys`
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# Optional NodeID, default 0
FERRET_NODE_ID=
