# Copy to .env and set your database URL.
# DATABASE_URL is read by the app and by Diesel CLI (e.g. diesel migration run).
DATABASE_URL=postgres://user:password@localhost/wetty_chat

# AWS / S3 Compatible
S3_BUCKET_NAME=wetty-chat-local-dev
AWS_REGION=us-west-2
# S3_ENDPOINT_URL=https://<namespace>.compat.objectstorage.<region>.oraclecloud.com
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# VAPID keys
# Generate with `npx web-push generate-vapid-keys`
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# Optional NodeID, default 0
FERRET_NODE_ID=

# DISCUZ
DISCUZ_DB_URL=mysql://root:example@127.0.0.1:3306/discuz
AUTH_METHOD=Discuz
DISCUZ_COOKIE_PREFIX=o2L2_2132
DISCUZ_AUTHKEY=myauthkey
